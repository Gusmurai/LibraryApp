<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="250.0" prefWidth="350.0" spacing="15.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <Label text="%label.currentPassword" />
    <PasswordField fx:id="oldPasswordField" />

    <Label text="%label.newPassword" />
    <PasswordField fx:id="newPasswordField" />

    <Label text="%label.confirmNewPassword" />
    <PasswordField fx:id="confirmPasswordField" />

    <HBox alignment="BOTTOM_RIGHT" spacing="10.0" VBox.vgrow="ALWAYS">
        <Button text="%button.cancel" />
        <Button text="%button.change" />
    </HBox>
</VBox>
