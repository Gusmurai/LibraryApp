<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="500.0" prefWidth="800.0" spacing="15.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ru.library.libraryapp.controllers.CopiesController">
    <padding>
        <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
    </padding>
    <children>
        <Label fx:id="lblBookInfo" text="%button.showCopies">
            <font>
                <Font name="System Bold" size="16.0" />
            </font>
        </Label>

        <HBox alignment="CENTER_LEFT" spacing="10.0">
            <children>
                <Label text="%label.search" />
                <TextField fx:id="searchInvField" prefWidth="100.0" />
                <Label text="%label.status">
                    <HBox.margin>
                        <Insets left="10.0" />
                    </HBox.margin>
                </Label>
                <ComboBox fx:id="statusFilterCombo" prefWidth="150.0" promptText="%status.all" />
                <Region HBox.hgrow="ALWAYS" />
                <Button fx:id="btnCopyFormular" text="%button.formular" />
                <Button fx:id="btnDelivery" text="%button.delivery" />
                <Button fx:id="btnWriteOff" text="%button.writeOff" />
            </children>
        </HBox>

        <TableView fx:id="copiesTable" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colInvNumber" prefWidth="150.0" text="%column.inv" />
                <TableColumn fx:id="colPrice" prefWidth="150.0" text="%column.price" />
                <TableColumn fx:id="colStatus" prefWidth="200.0" text="%column.status" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>
    </children>
</VBox>
