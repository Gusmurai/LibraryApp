<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="460.0" prefWidth="900.0" spacing="12.0" xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="ru.library.libraryapp.controllers.CopyHistoryController">
    <padding>
        <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
    </padding>

    <TableView fx:id="historyTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colReader" prefWidth="220.0" text="%column.reader" />
            <TableColumn fx:id="colTicket" prefWidth="80.0" text="%column.ticket" />
            <TableColumn fx:id="colPhone" prefWidth="125.0" text="%column.phone" />
            <TableColumn fx:id="colLendDate" prefWidth="100.0" text="%column.issued" />
            <TableColumn fx:id="colDueDate" prefWidth="100.0" text="%column.due" />
            <TableColumn fx:id="colReturnDate" prefWidth="100.0" text="%button.return" />
            <TableColumn fx:id="colLendingStatus" prefWidth="110.0" text="%column.status" />
            <TableColumn fx:id="colEmployee" prefWidth="130.0" text="%column.employee" />
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
    </TableView>

    <HBox alignment="CENTER_RIGHT">
        <Button fx:id="btnClose" minWidth="90.0" text="%button.close" />
    </HBox>
</VBox>
