<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="400.0" prefWidth="850.0" spacing="15.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
    <padding>
        <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
    </padding>
    <children>
        <Label fx:id="lblCopyInfo" text="Книга: Название (Инв. №00)">
            <font>
                <Font name="System Bold" size="14.0" />
            </font>
        </Label>
        <TableView fx:id="historyTable" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colReader" prefWidth="200.0" text="Читатель" />
                <TableColumn fx:id="colTicket" prefWidth="80.0" text="Билет" />
                <TableColumn fx:id="colPhone" prefWidth="120.0" text="Телефон" />
                <TableColumn fx:id="colLendDate" prefWidth="100.0" text="Дата" />
                <TableColumn fx:id="colDueDate" prefWidth="100.0" text="Вернуть до" />
                <TableColumn fx:id="colReturnDate" prefWidth="100.0" text="Дата возврата" />
                <TableColumn fx:id="colEmployee" prefWidth="120.0" text="Сотрудник" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>
        <HBox alignment="CENTER_RIGHT">
            <Button text="Закрыть" />
        </HBox>
    </children>
</VBox>