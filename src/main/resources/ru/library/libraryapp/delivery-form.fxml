<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox prefWidth="400.0" spacing="20.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
    <children>
        <Label fx:id="lblDeliveryTitle" text="Поставка: Название книги">
            <font>
                <Font name="System Bold" size="14.0" />
            </font>
        </Label>
        <GridPane hgap="10.0" vgap="15.0">
            <columnConstraints>
                <ColumnConstraints hgrow="SOMETIMES" minWidth="120.0" />
                <ColumnConstraints hgrow="ALWAYS" />
            </columnConstraints>
            <children>
                <Label text="Поставщик:" />
                <VBox spacing="5.0" GridPane.columnIndex="1">
                    <ComboBox fx:id="supplierCombo" maxWidth="1.7976931348623157E308" promptText="Выберите поставщика..." />
                    <CheckBox fx:id="noSupplierCheck" text="Без поставщика" />
                </VBox>

                <Label text="Стоимость за шт.:" GridPane.rowIndex="1" />
                <TextField fx:id="priceField" promptText="0.00" GridPane.rowIndex="1" GridPane.columnIndex="1" />

                <Label text="Количество:" GridPane.rowIndex="2" />
                <TextField fx:id="quantityField" promptText="1" GridPane.rowIndex="2" GridPane.columnIndex="1" />
            </children>
        </GridPane>
        <HBox alignment="CENTER_RIGHT" spacing="10.0">
            <Button text="Отмена" />
            <Button text="Принять" />
        </HBox>
    </children>
</VBox>