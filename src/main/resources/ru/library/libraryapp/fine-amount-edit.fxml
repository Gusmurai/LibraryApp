<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox prefWidth="350.0" spacing="20.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
    <padding>
        <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
    </padding>
    <children>
        <Label text="Изменение суммы штрафа">
            <font><Font name="System Bold" size="14.0" /></font>
        </Label>
        <VBox spacing="5.0">
            <Label fx:id="lblCurrentFineAmount" text="Текущая сумма: 0.00 ₽" />
            <HBox alignment="CENTER_LEFT" spacing="10.0">
                <children>
                    <Label text="Новая сумма:" />
                    <TextField fx:id="newAmountField" prefWidth="150.0" />
                </children>
                <VBox.margin><Insets top="10.0" /></VBox.margin>
            </HBox>
        </VBox>
        <HBox alignment="CENTER_RIGHT" spacing="10.0">
            <Button text="Отмена" minWidth="80.0" />
            <Button text="Сохранить" minWidth="100.0" />
        </HBox>
    </children>
</VBox>