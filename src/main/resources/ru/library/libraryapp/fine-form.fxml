<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox prefWidth="400.0" spacing="15.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
    <children>
        <Label fx:id="lblFineTitle" text="Штраф: Название">
            <font>
                <Font name="System Bold" size="15.0" />
            </font>
        </Label>
        <GridPane hgap="10.0" vgap="15.0">
            <columnConstraints>
                <ColumnConstraints hgrow="SOMETIMES" minWidth="120.0" />
                <ColumnConstraints hgrow="ALWAYS" />
            </columnConstraints>
            <children>
                <Label text="Статья штрафа:" />
                <ComboBox fx:id="fineArticleCombo" maxWidth="Infinity" disable="true" />

                <Label text="Сумма к оплате:" GridPane.rowIndex="1" />
                <TextField fx:id="fineAmountField" GridPane.rowIndex="1" GridPane.columnIndex="1" />

                <CheckBox fx:id="isPaidImmediately" text="Оплачено сразу" GridPane.rowIndex="2" GridPane.columnIndex="1" />

                <Label text="Заметка:" GridPane.rowIndex="3" />
                <TextArea fx:id="fineNoteArea" prefHeight="80.0" GridPane.rowIndex="3" GridPane.columnIndex="1" />
            </children>
        </GridPane>
        <HBox alignment="CENTER_RIGHT" spacing="10.0">
            <Button fx:id="btnCancelFine" text="Отмена" />
            <Button fx:id="btnConfirmFine" text="Оформить" />
        </HBox>
    </children>
</VBox>