<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefHeight="300.0" prefWidth="400.0" spacing="20.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ru.library.libraryapp.controllers.LoginController">
    <padding>
        <Insets bottom="30.0" left="40.0" right="40.0" top="30.0" />
    </padding>

    <Label text="Вход в систему">
        <font>
            <Font name="System Bold" size="20.0" />
        </font>
    </Label>

    <VBox spacing="10.0">
        <Label text="Логин:" />
        <TextField fx:id="loginField" promptText="Введите ваш логин" />

        <Label text="Пароль:" />
        <PasswordField fx:id="passwordField" promptText="Введите ваш пароль" />
    </VBox>

    <Label fx:id="lblError" text="Неверный логин или пароль" textFill="RED" visible="false" />

    <Button fx:id="btnLogin" maxWidth="1.7976931348623157E308" onAction="#onLoginClick" prefHeight="35.0" text="Войти" />
</VBox>
