<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="500.0" prefWidth="850.0" spacing="15.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ru.library.libraryapp.controllers.ReaderSelectController">
    <padding>
        <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
    </padding>
    <children>
        <Label text="Выберите читателя для оформления брони:">
            <font>
                <Font name="System Bold" size="13.0" />
            </font>
        </Label>
        <TextField fx:id="searchReaderInSelect" promptText="Поиск по фамилии, номеру билета или телефону..." />

        <TableView fx:id="readerSelectionTable" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colSelTicket" prefWidth="80.0" text="№ Билета" />
                <TableColumn fx:id="colSelLastName" prefWidth="150.0" text="Фамилия" />
                <TableColumn fx:id="colSelFirstName" prefWidth="150.0" text="Имя" />
                <TableColumn fx:id="colSelPatronymic" prefWidth="150.0" text="Отчество" />
                <TableColumn fx:id="colSelPhone" prefWidth="130.0" text="Телефон" />
                <TableColumn fx:id="colSelStatus" prefWidth="100.0" text="Статус" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>

        <HBox alignment="CENTER_RIGHT" spacing="10.0">
            <children>
                <Button text="Отмена" minWidth="80.0" onAction="#onCancelClick" />
                <Button fx:id="btnFinalSelectReader" prefWidth="100.0" text="Выбрать" onAction="#onSelectClick" />
            </children>
        </HBox>
    </children>
</VBox>
