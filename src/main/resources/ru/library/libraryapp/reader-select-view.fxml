<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="500.0" prefWidth="850.0" spacing="15.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ru.library.libraryapp.controllers.ReaderSelectController">
    <padding>
        <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
    </padding>
    <children>
        <Label text="%label.selectReaderForReservation">
            <font>
                <Font name="System Bold" size="13.0" />
            </font>
        </Label>
        <TextField fx:id="searchReaderInSelect" promptText="%prompt.searchReaderSelect" />

        <TableView fx:id="readerSelectionTable" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colSelTicket" prefWidth="80.0" text="%column.ticket" />
                <TableColumn fx:id="colSelLastName" prefWidth="150.0" text="%column.lastName" />
                <TableColumn fx:id="colSelFirstName" prefWidth="150.0" text="%column.firstName" />
                <TableColumn fx:id="colSelPatronymic" prefWidth="150.0" text="%column.patronymic" />
                <TableColumn fx:id="colSelPhone" prefWidth="130.0" text="%column.phone" />
                <TableColumn fx:id="colSelStatus" prefWidth="100.0" text="%column.status" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>

        <HBox alignment="CENTER_RIGHT" spacing="10.0">
            <children>
                <Button minWidth="80.0" onAction="#onCancelClick" text="%button.cancel" />
                <Button fx:id="btnFinalSelectReader" onAction="#onSelectClick" prefWidth="100.0" text="%button.select" />
            </children>
        </HBox>
    </children>
</VBox>
