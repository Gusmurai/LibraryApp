<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox prefWidth="350.0" spacing="15.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
    <children>
        <Label text="Списание экземпляра">
            <font>
                <Font name="System Bold" size="15.0" />
            </font>
        </Label>
        <VBox spacing="5.0">
            <Label fx:id="lblWriteOffInv" text="Инв. номер: 000" />
            <Label fx:id="lblWriteOffBook" text="Книга: Название" wrapText="true" />
        </VBox>
        <Label text="Укажите причину:" />
        <ComboBox fx:id="reasonCombo" maxWidth="1.7976931348623157E308" promptText="Выберите причину..." />
        <HBox alignment="CENTER_RIGHT" spacing="10.0">
            <padding>
                <Insets top="10.0" />
            </padding>
            <Button text="Отмена" />
            <Button text="Списать" />
        </HBox>
    </children>
</VBox>