<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefWidth="350.0" spacing="15.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ru.library.libraryapp.controllers.WriteOffFormController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
    <children>
        <Label text="%window.title.writeOff">
            <font>
                <Font name="System Bold" size="15.0" />
            </font>
        </Label>
        <VBox spacing="5.0">
            <Label fx:id="lblWriteOffInv" text="%column.inv" />
            <Label fx:id="lblWriteOffBook" text="%column.title" wrapText="true" />
        </VBox>
        <Label text="%label.writeOffReason" />
        <ComboBox fx:id="reasonCombo" maxWidth="1.7976931348623157E308" promptText="%prompt.selectReason" />
        <HBox alignment="CENTER_RIGHT" spacing="10.0">
            <padding>
                <Insets top="10.0" />
            </padding>
            <Button fx:id="btnCancel" text="%button.cancel" onAction="#onCancelClick" />
            <Button fx:id="btnSave" text="%button.writeOff" onAction="#onSaveClick" />
        </HBox>
    </children>
</VBox>
